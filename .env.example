# ============================================
# BebekStüdyo - API Anahtarları Yapılandırması
# ============================================
# Bu dosyayı .env olarak kopyalayın ve kendi API anahtarlarınızı girin:
# cp .env.example .env

# ---- Supabase (Zorunlu - Auth ve Veritabanı) ----
# https://supabase.com adresinden ücretsiz proje oluşturun
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---- OpenAI (İsim Önerileri & Bebek Görseli için) ----
# https://platform.openai.com/api-keys adresinden alın
# Modeller: gpt-4o-mini (isim önerileri), dall-e-3 (görsel oluşturma)
VITE_OPENAI_API_KEY=sk-your-openai-api-key

# ---- Google Gemini (OpenAI alternatifi - İsim Önerileri için) ----
# https://aistudio.google.com/app/apikey adresinden alın
# OpenAI yoksa Gemini kullanılır
VITE_GEMINI_API_KEY=your-gemini-api-key

# ---- Replicate (Bebek Görseli için - Opsiyonel) ----
# https://replicate.com/account/api-tokens adresinden alın
# OpenAI DALL-E yerine Replicate kullanılabilir
VITE_REPLICATE_API_KEY=your-replicate-api-key

# ============================================
# NOT: En az bir AI API anahtarı gereklidir.
# Önerilen kombinasyon:
# - OpenAI (hem metin hem görsel için)
# VEYA
# - Gemini (metin) + Replicate (görsel)
# ============================================
